{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Naive",
  "description": "AI Agent Primitives — email, social media, video, image generation, payments, browser automation, and 100+ integrations for your AI agent.",
  "colors": {
    "primary": "#000000",
    "light": "#fbf9f6",
    "dark": "#000000"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://usenaive.ai"
  },
  "appearance": {
    "default": "dark",
    "strict": false
