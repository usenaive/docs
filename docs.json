  "background": {
    "color": {
      "light": "#fbf9f6",
      "dark": "#0a0a0a"
    }
  },
  "fonts": {
    "family": "Geist",
    "weight": 400,
    "heading": {
      "family": "Geist",
      "weight": 600
    }
  },
  "styling": {
    "eyebrow": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
