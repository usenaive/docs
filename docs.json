{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Naive",
  "description": "AI Agent Primitives — email, social media, video, image generation, payments, browser automation, and 100+ integrations for your AI agent.",
  "colors": {
    "primary": "#000000",
    "light": "#fbf9f6",
    "dark": "#000000"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://usenaive.ai"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "color": {
      "light": "#fbf9f6",
      "dark": "#0a0a0a"
    }
  },
  "fonts": {
    "family": "Geist",
    "weight": 400,
    "heading": {
      "family": "Geist",
      "weight": 600
    }
  },
  "styling": {
    "eyebrow": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://usenaive.ai/developers"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://usenaive.ai/developers"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/usenaive",
      "x": "https://x.com/usenaive"
    }
  },
